# Source database
POSTGRES_SOURCE_USER=postgres
POSTGRES_SOURCE_PASSWORD=postgres
POSTGRES_SOURCE_DB=db_real
POSTGRES_SOURCE_SERVER=postgres-source:5432

# Internal database
POSTGRES_INTERNAL_USER=admin_fraude
POSTGRES_INTERNAL_PASSWORD=senha_segura
POSTGRES_INTERNAL_DB=db_seguranca
POSTGRES_INTERNAL_SERVER=postgres-internal:5432

# Shared services
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
WORKER_GROUP_ID=group_worker_insurance
KAFKA_GROUP_ID=group_anomaly_handler

# Worker configuration
TARGET_TABLE=insurance_claims
COLUMNS_TO_IGNORE=id,FraudFound_P,PolicyNumber,RepNumber
RF_HIGH_CONFIDENCE_THRESHOLD=0.85
RF_MODERATE_THRESHOLD=0.4
IF_COMBINED_THRESHOLD=-0.15
IF_STANDALONE_THRESHOLD=-0.1
CONTAMINATION=0.01

# Email alerts
SENDER_EMAIL=your_email@example.com
EMAIL_PASSWORD=your_app_password
RECIEVER_EMAIL=receiver@example.com

# Seed container
POSTGRES_SOURCE_HOST=postgres-source
POSTGRES_SOURCE_PORT=5432
POSTGRES_SOURCE_USER=postgres
POSTGRES_SOURCE_PASSWORD=postgres
POSTGRES_SOURCE_DB=db_real
POSTGRES_INTERNAL_HOST=postgres-internal
POSTGRES_INTERNAL_PORT=5432
POSTGRES_INTERNAL_USER=admin_fraude
POSTGRES_INTERNAL_PASSWORD=senha_segura
POSTGRES_INTERNAL_DB=db_seguranca
TARGET_TABLE=insurance_claims
FRAUD_COLUMN=FraudFound_P
CSV_FILE=insurance_fraud.csv
POLL_INTERVAL=3
POLL_TIMEOUT=600
